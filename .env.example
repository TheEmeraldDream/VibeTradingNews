# Anthropic API Key (required for Claude strategy assistant)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Alpaca Brokerage API Keys
# Get from https://alpaca.markets — use paper trading keys to start
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Set to "true" for paper trading (recommended), "false" for live trading
ALPACA_PAPER=true
